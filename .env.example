# Environment Configuration for ARES

# Application
ARES_ENV=development
ARES_DEBUG=true
ARES_HOST=0.0.0.0
ARES_PORT=8000

# Database
DATABASE_URL=postgresql://tapasvi@localhost/ares_db
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:8b

# Burp Suite
BURP_API_URL=http://localhost:1337
BURP_API_KEY=

# MCP Server
MCP_HOST=localhost
MCP_PORT=8001

# Security
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=/mnt/d_drive/ares/logs/ares.log

# Scanning
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT=3600
RATE_LIMIT=100

# Model Training
TRAINING_DATA_DIR=/mnt/d_drive/ares/data/training
MODEL_OUTPUT_DIR=/mnt/d_drive/ares/models

# Storage
SCAN_RESULTS_DIR=/mnt/d_drive/ares/data/scan_results
REPORTS_DIR=/mnt/d_drive/ares/data/reports
